<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Welding Shop - Production Control Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-color: #0f1115;
            --panel-bg: #161920;
            --panel-header: #1e222b;
            --text-main: #f1f2f6;
            --text-muted: #747d8c;
            --accent-neon: #00eaff;
            --accent-orange: #ff9f43;
            --accent-red: #ff4d4d;
            --border: #262c38;
        }

        body {
            font-family: 'Kanit', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            margin: 0;
            padding: 25px;
        }

        .header-title {
            text-align: center;
            margin-bottom: 30px;
        }

        .header-title h1 {
            margin: 0;
            font-size: 2rem;
            letter-spacing: 1px;
            color: var(--text-main);
            text-transform: uppercase;
        }
        
        .header-title h1 span {
            color: var(--accent-neon);
        }

        .dashboard-grid {
            display: grid;
            grid-template-columns: 320px 1fr;
            gap: 25px;
            max-width: 1600px;
            margin: 0 auto;
        }

        @media (max-width: 1024px) {
            .dashboard-grid { grid-template-columns: 1fr; }
        }

        .panel {
            background-color: var(--panel-bg);
            border-radius: 12px;
            border: 1px solid var(--border);
            overflow: hidden;
            box-shadow: 0 10px 25px rgba(0,0,0,0.4);
        }

        .panel-header {
            background-color: var(--panel-header);
            padding: 15px 20px;
            font-weight: 600;
            font-size: 1.1rem;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .panel-body {
            padding: 20px;
        }

        .input-group {
            margin-bottom: 18px;
        }

        label {
            display: block;
            font-size: 0.85rem;
            color: var(--text-muted);
            margin-bottom: 6px;
            text-transform: uppercase;
            font-weight: 500;
        }

        input, select {
            width: 100%;
            padding: 12px;
            border-radius: 8px;
            border: 1px solid var(--border);
            background-color: #1e222b;
            color: var(--text-main);
            font-family: 'Kanit', sans-serif;
            font-size: 1rem;
            box-sizing: border-box;
            transition: all 0.3s ease;
        }

        input:focus, select:focus {
            outline: none;
            border-color: var(--accent-neon);
            box-shadow: 0 0 10px rgba(0, 234, 255, 0.2);
        }

        .divider {
            height: 1px;
            background-color: var(--border);
            margin: 25px 0 20px 0;
        }

        .btn-calc {
            width: 100%;
            padding: 15px;
            margin-top: 10px;
            background-color: var(--accent-red);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 1.1rem;
            font-weight: 600;
            font-family: 'Kanit', sans-serif;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(255, 77, 77, 0.3);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .btn-calc:hover {
            background-color: #ff3333;
            box-shadow: 0 6px 20px rgba(255, 77, 77, 0.5);
            transform: translateY(-2px);
        }

        .btn-calc:active {
            transform: translateY(0);
        }

        .results-container {
            display: flex;
            flex-direction: column;
            gap: 25px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            text-align: center;
        }

        th {
            background-color: var(--panel-header);
            color: var(--text-muted);
            font-weight: 500;
            font-size: 0.9rem;
            padding: 12px;
            border-bottom: 2px solid var(--border);
        }

        td {
            padding: 14px 12px;
            border-bottom: 1px solid var(--border);
            font-size: 0.95rem;
        }

        tr:hover td {
            background-color: rgba(255,255,255,0.02);
        }

        .highlight-neon { color: var(--accent-neon); font-weight: 600; }
        .highlight-orange { color: var(--accent-orange); font-weight: 600; }
        .highlight-blue { color: #54a0ff; font-weight: 600; }

        .total-row {
            background-color: #1a1e26;
            font-weight: 600;
        }
        .total-row td {
            border-top: 2px solid var(--border);
            border-bottom: 2px solid var(--border);
            color: #fff;
        }
    </style>
</head>
<body>

    <div class="header-title">
        <h1>Welding Shop <span>Production Control Center</span></h1>
    </div>

    <div class="dashboard-grid">
        
        <div class="panel">
            <div class="panel-header">⚙️ DATA PARAMETERS</div>
            <div class="panel-body">
                <div class="input-group">
                    <label>Main Takt Time (วินาที)</label>
                    <input type="number" id="mainTT" value="81">
                </div>

                <div class="input-group">
                    <label>เงื่อนไขเวลาทำงาน (OT)</label>
                    <select id="otType">
                        <option value="0">ไม่มี OT (8 ชั่วโมง)</option>
                        <option value="0.5">มี OT 0.5 ชั่วโมง</option>
                        <option value="1.0">มี OT 1.0 ชั่วโมง</option>
                        <option value="1.5">มี OT 1.5 ชั่วโมง</option>
                        <option value="2.0" selected>มี OT 2.0 ชั่วโมง</option>
                    </select>
                </div>

                <div class="divider"></div>
                <label style="color: var(--accent-neon); margin-bottom: 15px;">MODEL RATIO SETTING (%)</label>

                <div class="input-group">
                    <label>C-CAB Ratio (%)</label>
                    <input type="number" step="0.1" id="ratioC" value="11.1">
                </div>
                <div class="input-group">
                    <label>D-CAB Ratio (%)</label>
                    <input type="number" step="0.1" id="ratioD" value="57.5">
                </div>
                <div class="input-group">
                    <label>SUV Ratio (%)</label>
                    <input type="number" step="0.1" id="ratioSUV" value="8.4">
                </div>
                <div class="input-group">
                    <label>500D Ratio (%)</label>
                    <input type="number" step="0.1" id="ratio500D" value="23.0">
                </div>

                <button class="btn-calc" onclick="calculateAll()">⚙️ Calculate Now</button>
            </div>
        </div>

        <div class="results-container">
            
            <div class="panel">
                <div class="panel-header">📊 HOURLY PRODUCTION CONTROL BREAKDOWN (TARGET 97.0% - INTEGER)</div>
                <div style="overflow-x: auto;">
                    <table>
                        <thead>
                            <tr>
                                <th>ชั่วโมงที่</th>
                                <th>Plan 100% (คัน)</th>
                                <th>Target 97% (คัน)</th>
                                <th>C-CAB (คัน)</th>
                                <th>D-CAB (คัน)</th>
                                <th>SUV (คัน)</th>
                                <th>500D (คัน)</th>
                            </tr>
                        </thead>
                        <tbody id="hourlyTableBody">
                            <tr><td colspan="7" style="color: var(--text-muted); padding: 30px;">กรุณากดปุ่ม Calculate Now เพื่อแสดงผลลัพธ์</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="panel">
                <div class="panel-header">⏱️ PROCESS TAKT TIME CALCULATION</div>
                <div style="overflow-x: auto;">
                    <table>
                        <thead>
                            <tr>
                                <th>ชื่อ Process / ส่วนการผลิต</th>
                                <th>สัดส่วน Ratio รวม (%)</th>
                                <th>สูตรการคำนวณ</th>
                                <th>Process Takt Time (วินาที)</th>
                            </tr>
                        </thead>
                        <tbody id="processTableBody">
                            <tr><td colspan="4" style="color: var(--text-muted); padding: 30px;">กรุณากดปุ่ม Calculate Now เพื่อแสดงผลลัพธ์</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>

    <script>
        // ข้อมูลวินาทีทำงานอ้างอิงจากแผนการผลิตฐาน (Main TT = 81 วินาที)
        const baseSeconds = {
            "1": 44 * 81,
            "2": 45 * 81,
            "3": 37 * 81,
            "4": 45 * 81,
            "5": 44 * 81,
            "6": 45 * 81,
            "7": 37 * 81,
            "8": 44 * 81,
            "9_OT05": 22 * 81,
            "9_OT10": 45 * 81,
            "10_OT15": 22 * 81,
            "10_OT2.0": 44 * 81 
        };

        function calculateAll() {
            const mainTT = parseFloat(document.getElementById('mainTT').value) || 0;
            const c = parseFloat(document.getElementById('ratioC').value) || 0;
            const d = parseFloat(document.getElementById('ratioD').value) || 0;
            const suv = parseFloat(document.getElementById('ratioSUV').value) || 0;
            const d500 = parseFloat(document.getElementById('ratio500D').value) || 0;
            const otType = document.getElementById('otType').value;

            // จัดเตรียม Timeline เวลาทำงาน
            let timeline = [];
            for (let i = 1; i <= 8; i++) {
                timeline.push({ name: i, sec: baseSeconds[i.toString()] });
            }

            if (otType === "0.5") {
                timeline.push({ name: "9 (OT)", sec: baseSeconds["9_OT05"] });
            } else if (otType === "1.0") {
                timeline.push({ name: "9 (OT)", sec: baseSeconds["9_OT10"] });
            } else if (otType === "1.5") {
                timeline.push({ name: "9 (OT)", sec: baseSeconds["9_OT10"] });
                timeline.push({ name: "10 (OT)", sec: baseSeconds["10_OT15"] });
            } else if (otType === "2.0") {
                timeline.push({ name: "9 (OT)", sec: baseSeconds["9_OT10"] });
                timeline.push({ name: "10 (OT)", sec: baseSeconds["10_OT2.0"] });
            }

            let hourlyHtml = "";
            let tPlan = 0, tTarget = 0, tC = 0, tD = 0, tSUV = 0, t500 = 0;

            timeline.forEach(item => {
                // คำนวณแผน 100% ประจำชั่วโมง (ปัดเศษทิ้งตามขีดความสามารถการผลิตจริง)
                let hrPlan = mainTT > 0 ? Math.floor(item.sec / mainTT) : 0;
                
                // คำนวณเป็นจำนวนเต็มทั้งหมดด้วยการปัดเศษ (Math.round) เพื่อความเหมาะสมหน้างาน
                let hrTarget = Math.round(hrPlan * 0.97);
                let hrC = Math.round(hrPlan * (c / 100));
                let hrD = Math.round(hrPlan * (d / 100));
                let hrSUV = Math.round(hrPlan * (suv / 100));
                let hr500 = Math.round(hrPlan * (d500 / 100));

                // บวกสะสมยอดรวมจากค่าจำนวนเต็มที่ปัดเศษแล้ว เพื่อให้เลขแนวตั้ง-แนวนอนสัมพันธ์กันพอดี
                tPlan += hrPlan;
                tTarget += hrTarget;
                tC += hrC;
                tD += hrD;
                tSUV += hrSUV;
                t500 += hr500;

                hourlyHtml += `
                    <tr>
                        <td>ชั่วโมงที่ ${item.name}</td>
                        <td class="highlight-blue">${hrPlan}</td>
                        <td class="highlight-orange">${hrTarget}</td>
                        <td>${hrC}</td>
                        <td>${hrD}</td>
                        <td>${hrSUV}</td>
                        <td>${hr500}</td>
                    </tr>
                `;
            });

            // แถวสรุปรวมท้ายตาราง (เป็นจำนวนเต็มทั้งหมด)
            hourlyHtml += `
                <tr class="total-row">
                    <td>TOTAL VOLUME</td>
                    <td class="highlight-blue">${tPlan}</td>
                    <td class="highlight-orange">${tTarget}</td>
                    <td>${tC}</td>
                    <td>${tD}</td>
                    <td>${tSUV}</td>
                    <td>${t500}</td>
                </tr>
            `;
            document.getElementById('hourlyTableBody').innerHTML = hourlyHtml;

            // --- ตารางที่ 2: คำนวณ Process Takt Time ---
            const processConfigs = [
                { name: "C-CAB", r: c },
                { name: "D-CAB", r: d },
                { name: "SUV", r: suv },
                { name: "500D", r: d500 },
                { name: "C-CAB + D-CAB", r: c + d },
                { name: "D-CAB + SUV", r: d + suv },
                { name: "SUV + 500D", r: suv + d500 },
                { name: "COMMON (C+D+SUV+500D)", r: c + d + suv + d500 }
            ];

            let procHtml = "";
            processConfigs.forEach(p => {
                let pTT = p.r > 0 ? Math.floor(mainTT / (p.r / 100)) : 0;
                procHtml += `
                    <tr>
                        <td style="text-align: left; padding-left: 30px; font-weight: 500;">${p.name}</td>
                        <td>${p.r.toFixed(1)}%</td>
                        <td style="color: var(--text-muted); font-size: 0.85rem;">${mainTT} / ${p.r.toFixed(3)}%</td>
                        <td class="highlight-neon">${pTT}</td>
                    </tr>
                `;
            });
            document.getElementById('processTableBody').innerHTML = procHtml;
        }
        
        // รันคำนวณตั้งต้นทันทีเมื่อโหลดหน้าเว็บสำเร็จ
        window.onload = function() {
            calculateAll();
        };
    </script>
</body>
</html>
